  <Port Color="#ffe4c4" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="full" Parent="my_fifo4" Side="right" Width="30" X="0.85" Y="0.327273"/>
  <Port Color="#b8860b" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="empty" Parent="my_fifo4" Side="right" Width="30" X="0.85" Y="0.527273"/>
  <Port Color="#ffebcd" Connect="mf_buf_prof_full[0]" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="prog_full" Parent="my_fifo4" Side="right" Width="30" X="0.85" Y="0.727273"/>
  <Port Color="#0000ff" Connect="mf_buf_out_da[0*FIFO_WIDTH+FIFO_WIDTH-1 : 0*FIFO_WIDTH]" Datasize="DATA_W-1:0" Datatype="wire" Description="" Height="30" Inout="output" Name="dout" Parent="my_fifo4" Side="bottom" Width="30" X="0.585" Y="0.863636"/>
