 <Module Category="Current" Class="mf_out_vld_delay" Code="    reg [DELAY-1:0] shift_reg;&#xa;&#xa;    integer i;&#xa;    always @(posedge clk) begin&#xa;        // 移位寄存器操作&#xa;        shift_reg[0] &lt;= D;&#xa;        for (i = 1; i &lt; DELAY; i = i + 1) begin&#xa;            shift_reg[i] &lt;= shift_reg[i-1];&#xa;        end&#xa;&#xa;        // 输出为移位寄存器的最后一位&#xa;        Q &lt;= shift_reg[DELAY-1];&#xa;    end" Color="#d3d3d3" Comment="" Height="220" Name="mf_out_vld_delay4" Parameters="DELAY = 10; //&#xa;" Parent="dehaze_minfir" Type="model" Width="200" X="150.413" Y="70.9917">
  <Port Color="#faebd7" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="clk" Parent="mf_out_vld_delay4" Side="left" Width="30" X="-0.15" Y="0.259091"/>
  <Port Color="#00ffff" Connect="mf_out_vld_r" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="D" Parent="mf_out_vld_delay4" Side="left" Width="30" X="-0.15" Y="0.595455"/>
  <Port Color="#7fffd4" Connect="mf_out_vld_w_wire" Datasize="1" Datatype="reg" Description="" Height="30" Inout="output" Name="Q" Parent="mf_out_vld_delay4" Side="right" Width="30" X="0.85" Y="0.427273"/>
 </Module>
 <Module Category="Current" Class="my_fifo" Code=" reg [DATA_W-1:0] mem [0:DEPTH-1];&#xa;    reg [ADDR_W-1:0] wr_ptr, rd_ptr;&#xa;    reg [ADDR_W:0]   count;&#xa;    reg [DATA_W-1:0] dout_r;&#xa;&#xa;    assign full      = (count == DEPTH);&#xa;    assign empty     = (count == 0);&#xa;    localparam THRESH = 960;&#xa;    assign prog_full = (count >= (DEPTH - THRESH));&#xa;    assign dout      = dout_r;&#xa;&#xa;    // 写逻辑&#xa;    always @(posedge clk) begin&#xa;        if (!reset) begin&#xa;            wr_ptr &lt;= 0;&#xa;        end else if (write_en &amp;&amp; !full) begin&#xa;            mem[wr_ptr] &lt;= data_in;&#xa;            wr_ptr &lt;= (wr_ptr == DEPTH - 1) ? 0 : wr_ptr + 1;&#xa;        end&#xa;    end&#xa;&#xa;    // 读逻辑 + valid 输出&#xa;    always @(posedge clk) begin&#xa;        if (!reset) begin&#xa;            rd_ptr &lt;= 0;&#xa;            dout_r &lt;= 0;&#xa;            valid  &lt;= 0;&#xa;        end else if (read_en &amp;&amp; !empty) begin&#xa;            dout_r &lt;= mem[rd_ptr];&#xa;            rd_ptr &lt;= (rd_ptr == DEPTH - 1) ? 0 : rd_ptr + 1;&#xa;            valid  &lt;= 1;&#xa;        end else begin&#xa;            valid &lt;= 0;&#xa;        end&#xa;    end&#xa;&#xa;    // 计数器&#xa;    always @(posedge clk) begin&#xa;        if (!reset) begin&#xa;            count &lt;= 0;&#xa;        end else begin&#xa;            case ({write_en &amp;&amp; !full, read_en &amp;&amp; !empty})&#xa;                2'b10: count &lt;= count + 1;&#xa;                2'b01: count &lt;= count - 1;&#xa;                default: count &lt;= count;&#xa;            endcase&#xa;        end&#xa;    end" Color="#d3d3d3" Comment="" Height="220" Name="my_fifo4" Parameters="DATA_W = 18; //&#xa;DEPTH = 1026; //&#xa;ADDR_W = $clog2(DEPTH); //&#xa;" Parent="dehaze_minfir" Type="model" Width="200" X="490.083" Y="48.6777">
  <Port Color="#faebd7" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="clk" Parent="my_fifo4" Side="left" Width="30" X="-0.15" Y="0.127273"/>
  <Port Color="#00ffff" Connect="mf_buf_rst" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="reset" Parent="my_fifo4" Side="left" Width="30" X="-0.15" Y="0.327273"/>
  <Port Color="#7fffd4" Connect="mf_buf_in_da[0*FIFO_WIDTH+FIFO_WIDTH-1 : 0*FIFO_WIDTH]" Datasize="DATA_W-1:0" Datatype="wire" Description="" Height="30" Inout="input" Name="data_in" Parent="my_fifo4" Side="left" Width="30" X="-0.15" Y="0.527273"/>
  <Port Color="#f0ffff" Connect="mf_buf_wr[0]" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="write_en" Parent="my_fifo4" Side="left" Width="30" X="-0.15" Y="0.727273"/>
