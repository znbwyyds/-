<!DOCTYPE Robei>
<Module Category="Current" Class="module" Code="&#x9;// ******************** define variable types ******************** // &#xa;&#x9;reg           [19           : 0]          at_cnt  [2**RATIO-1 : 0] ;&#xa;&#x9;reg           [27           : 0]          at_sum  [2**RATIO-1 : 0] ;&#xa;&#x9;wire                                      at_cnt_rst_n             ;&#xa;&#x9;reg                                       at_in_vld_1d             ;&#xa;&#x9;reg           [DATA_WIDTH-1 : 0]          at_in_da_1d              ;&#xa;&#x9;reg                                       at_in_eof_1d             ;&#xa;&#x9;reg                                       at_in_eof_en             ;&#xa;&#x9;&#xa;&#x9;reg           [19           : 0]          at_top_cnt               ;&#xa;&#x9;reg           [19           : 0]          at_top_cnt_1d            ;&#xa;&#x9;reg           [27           : 0]          at_top_sum               ;&#xa;&#x9;reg           [27           : 0]          at_top_tmp1              ;&#xa;&#x9;reg           [27           : 0]          at_top_tmp2              ;&#xa;&#x9;reg           [27           : 0]          at_top_tmp3              ;&#xa;&#x9;reg                                       at_top_cal_fsh           ;&#xa;&#x9;reg                                       at_top_cal_fsh_1d        ;&#xa;&#x9;reg                                       at_top_cal_fsh_2d        ;&#xa;&#x9;wire                                      at_top_cal_fsh_pls       ;&#xa;&#xa;&#x9;integer                            &#x9;&#x9;  at_x_index               ;&#xa;&#x9;reg           [RATIO-1      : 0]   &#x9;&#x9;  at_cnt_index             ;&#xa;&#x9;&#xa;&#x9;&#xa;&#x9;// ************************* rank buffers ************************ // &#xa;&#x9;// at_cnt_rst_n&#xa;&#x9;assign at_cnt_rst_n = (~at_in_bof) &amp; rst_n;&#xa;&#x9;&#xa;&#x9;// at_in_vld_1d&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_in_vld_1d &lt;= 1'b0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else begin&#xa;&#x9;&#x9;&#x9;at_in_vld_1d &lt;= at_in_vld;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_in_da_1d&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_in_da_1d &lt;= 'd0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else begin&#xa;&#x9;&#x9;&#x9;at_in_da_1d &lt;= at_in_da;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_cnt&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;for (at_x_index = 0; at_x_index &lt; (2**RATIO); at_x_index = at_x_index + 1) begin&#xa;&#x9;&#x9;&#x9;&#x9;at_cnt[at_x_index] &lt;= 'd0;&#x9;&#x9;&#x9;&#xa;&#x9;&#x9;&#x9;end&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if(at_in_vld_1d == 1'b1) begin&#xa;&#x9;&#x9;&#x9;for (at_x_index = 0; at_x_index &lt; (2**RATIO); at_x_index = at_x_index + 1) begin&#xa;&#x9;&#x9;&#x9;&#x9;at_cnt[at_x_index] &lt;= (at_in_da_1d[DATA_WIDTH-1 : DATA_WIDTH-RATIO] ==  at_x_index)? &#xa;&#x9;&#x9;&#x9;&#x9;                      (at_cnt[at_x_index] + 'd1) : at_cnt[at_x_index];&#x9;&#x9;&#x9;&#xa;&#x9;&#x9;&#x9;end&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_sum&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;for (at_x_index = 0; at_x_index &lt; (2**RATIO); at_x_index = at_x_index + 1) begin&#xa;&#x9;&#x9;&#x9;&#x9;at_sum[at_x_index] &lt;= 'd0;&#x9;&#x9;&#x9;&#xa;&#x9;&#x9;&#x9;end&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if(at_in_vld_1d == 1'b1) begin&#xa;&#x9;&#x9;&#x9;for (at_x_index = 0; at_x_index &lt; (2**RATIO); at_x_index = at_x_index + 1) begin&#xa;&#x9;&#x9;&#x9;&#x9;at_sum[at_x_index] &lt;= (at_in_da_1d[DATA_WIDTH-1 : DATA_WIDTH-RATIO] ==  at_x_index)? &#xa;&#x9;&#x9;&#x9;&#x9;                      (at_sum[at_x_index] + at_in_da_1d) : at_sum[at_x_index];&#x9;&#x9;&#x9;&#xa;&#x9;&#x9;&#x9;end&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// ************************* rank calculate ********************** //&#xa;    // at_in_eof_1d&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_in_eof_1d &lt;= 1'b0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else begin&#xa;&#x9;&#x9;&#x9;at_in_eof_1d &lt;= at_in_eof;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#xa;&#x9;// at_in_eof_en&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_in_eof_en &lt;= 1'b0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if(at_in_bof == 1'b1) begin&#xa;&#x9;&#x9;&#x9;at_in_eof_en &lt;= 1'b0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if(at_in_eof_1d == 1'b1) begin&#xa;&#x9;&#x9;&#x9;at_in_eof_en &lt;= 1'b1;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_cnt_index&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_cnt_index &lt;= 2**RATIO - 'd1;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if((at_top_cnt &lt; (2**SAMPLE_SIZE)) &amp;&amp; (at_in_eof_en == 1'b1)) begin&#xa;&#x9;&#x9;&#x9;at_cnt_index &lt;= at_cnt_index - 'd1;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_top_cnt&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_cnt &lt;= 'd0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if((at_top_cnt &lt; (2**SAMPLE_SIZE)) &amp;&amp; (at_in_eof_en == 1'b1)) begin&#xa;&#x9;&#x9;&#x9;at_top_cnt &lt;= at_top_cnt + at_cnt[at_cnt_index];&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_top_cnt_1d&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_cnt_1d &lt;= 'd0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else begin&#xa;&#x9;&#x9;&#x9;at_top_cnt_1d &lt;= at_top_cnt;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#xa;&#x9;// at_top_sum&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_sum &lt;= 'd0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if((at_top_cnt &lt; (2**SAMPLE_SIZE)) &amp;&amp; (at_in_eof_en == 1'b1)) begin&#xa;&#x9;&#x9;&#x9;at_top_sum &lt;= at_top_sum + at_sum[at_cnt_index];&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_top_tmp1&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_tmp1 &lt;= 'd0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if((at_top_cnt >= (2**SAMPLE_SIZE)) &amp;&amp; (at_in_eof_en == 1'b1)) begin&#xa;&#x9;&#x9;&#x9;at_top_tmp1 &lt;= at_top_sum - at_sum[at_cnt_index+1];&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_top_tmp2&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_tmp2 &lt;= 'd0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if((at_top_cnt >= (2**SAMPLE_SIZE)) &amp;&amp; (at_in_eof_en == 1'b1)) begin&#xa;&#x9;&#x9;&#x9;at_top_tmp2 &lt;= ((2**SAMPLE_SIZE) - at_top_cnt_1d) * {(at_cnt_index + 6'd1), {(DATA_WIDTH-RATIO){1'b0}}};&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#xa;&#x9;// at_top_tmp3&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_tmp3 &lt;= 'd0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if((at_top_cnt >= (2**SAMPLE_SIZE)) &amp;&amp; (at_in_eof_en == 1'b1)) begin&#xa;&#x9;&#x9;&#x9;at_top_tmp3 &lt;= at_top_tmp1 + at_top_tmp2;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_top_cal_fsh&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_cal_fsh &lt;= 1'b0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if((at_top_cnt >= (2**SAMPLE_SIZE)) &amp;&amp; (at_in_eof_en == 1'b1)) begin&#xa;&#x9;&#x9;&#x9;at_top_cal_fsh &lt;= 1'b1;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else begin&#xa;&#x9;&#x9;&#x9;at_top_cal_fsh &lt;= 1'b0;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#xa;&#x9;// at_top_cal_fsh_pls&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin&#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_cal_fsh_1d &lt;= 1'b0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else begin&#xa;&#x9;&#x9;&#x9;at_top_cal_fsh_1d &lt;= at_top_cal_fsh;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#x9;&#xa;&#x9;always @ (posedge clk or negedge at_cnt_rst_n) begin &#xa;&#x9;&#x9;if(at_cnt_rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_top_cal_fsh_2d &lt;= 1'b0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else begin&#xa;&#x9;&#x9;&#x9;at_top_cal_fsh_2d &lt;= at_top_cal_fsh_1d;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#x9;&#x9;&#xa;&#x9;&#xa;&#x9;assign at_top_cal_fsh_pls = at_top_cal_fsh_1d &amp; (~at_top_cal_fsh_2d);&#xa;&#x9;&#xa;&#x9;&#xa;&#x9;// ************************ signals output *********************** //&#xa;&#x9;// at_out_da&#xa;&#x9;always @ (posedge clk or negedge rst_n) begin&#xa;&#x9;&#x9;if(rst_n == 1'b0) begin&#xa;&#x9;&#x9;&#x9;at_out_da &lt;= 'd0;&#xa;&#x9;&#x9;end&#xa;&#x9;&#x9;else if(at_top_cnt >= (2**SAMPLE_SIZE)) begin&#xa;&#x9;&#x9;&#x9;at_out_da &lt;= (at_top_cal_fsh_pls == 1'b1)? (at_top_tmp3 >> SAMPLE_SIZE) : at_out_da;&#xa;&#x9;&#x9;end&#xa;&#x9;end&#xa;&#x9;&#x9;&#x9;" Color="#d3d3d3" Comment="" Height="1080" Name="atmos_cal" Parameters="&#x9;  DATA_WIDTH       = 8     ,&#xa; &#x9;&#x9;  SAMPLE_SIZE      = 11    ,&#xa; &#x9;&#x9;  RATIO            = 6     &#xa;&#xa;&#xa;" Parent="0" Type="model" Width="1600" X="0" Y="0">
 <Port Color="#faebd7" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="clk" Parent="atmos_cal" Side="left" Width="30" X="-0.01875" Y="0.107407"/>
 <Port Color="#00ffff" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="rst_n" Parent="atmos_cal" Side="left" Width="30" X="-0.01875" Y="0.181481"/>
 <Port Color="#7fffd4" Connect="" Datasize="8" Datatype="wire" Description="" Height="30" Inout="input" Name="at_in_da" Parent="atmos_cal" Side="left" Width="30" X="-0.01875" Y="0.348148"/>
 <Port Color="#f0ffff" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="at_in_vld" Parent="atmos_cal" Side="left" Width="30" X="-0.01875" Y="0.425926"/>
 <Port Color="#f5f5dc" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="at_in_bof" Parent="atmos_cal" Side="left" Width="30" X="-0.01875" Y="0.5"/>
 <Port Color="#ffe4c4" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="at_in_eof" Parent="atmos_cal" Side="left" Width="30" X="-0.01875" Y="0.568519"/>
 <Port Color="#b8860b" Connect="" Datasize="8" Datatype="reg" Description="" Height="30" Inout="output" Name="at_out_da" Parent="atmos_cal" Side="right" Width="30" X="0.98125" Y="0.411111"/>
</Module>
