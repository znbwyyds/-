<!DOCTYPE Robei>
<Module Category="Current" Class="module" Code=" // 定义移位寄存器的深度和宽度&#xa;      reg [2:0] shift_reg [1:0];  // 深度为2，宽度为3的移位寄存器数组&#xa;      integer i;&#xa;  &#xa;      // 初始化移位寄存器&#xa;      initial begin&#xa;          for (i = 0; i &lt; 2; i = i + 1) begin&#xa;              shift_reg[i] = 3'b000;  // 每个寄存器的初始值为000&#xa;          end&#xa;      end&#xa;  &#xa;      // 移位寄存器操作&#xa;      always @(posedge CLK) begin&#xa;          // 时钟上升沿时移位&#xa;          shift_reg[0] &lt;= D;  // 输入数据D放入shift_reg[0]&#xa;          for (i = 2; i > 0; i = i - 1) begin&#xa;              shift_reg[i] &lt;= shift_reg[i-1];  // 其他数据右移&#xa;          end&#xa;      end&#xa;  &#xa;      // 输出寄存器最旧的数据&#xa;      assign Q = shift_reg[1];  // 输出最新移位后的数据" Color="#d3d3d3" Comment="" Height="1080" Name="gr_out_vld_delay" Parameters="" Parent="0" Type="model" Width="1600" X="0" Y="0">
 <Port Color="#faebd7" Connect="" Datasize="3" Datatype="wire" Description="" Height="30" Inout="input" Name="D" Parent="gr_out_vld_delay" Side="left" Width="30" X="-0.01875" Y="0.15463"/>
 <Port Color="#00ffff" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="CLK" Parent="gr_out_vld_delay" Side="left" Width="30" X="-0.01875" Y="0.439815"/>
 <Port Color="#7fffd4" Connect="" Datasize="3" Datatype="wire" Description="" Height="30" Inout="output" Name="Q" Parent="gr_out_vld_delay" Side="right" Width="30" X="0.98125" Y="0.302778"/>
</Module>
